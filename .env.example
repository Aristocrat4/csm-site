# Copy to .env.local and fill in. All are optional — the site builds and runs
# without them; integrations simply stay dormant until configured.

# Canonical URL (set once the custom domain is attached, before running ads).
NEXT_PUBLIC_SITE_URL=https://gala-d.vercel.app

# Web3Forms access key (free at https://web3forms.com — arrives by email).
NEXT_PUBLIC_WEB3FORMS_KEY=

# Calendly scheduling link, e.g. https://calendly.com/your-handle/15min
NEXT_PUBLIC_CALENDLY_URL=

# Intro video. ID only (not the full URL). Host is "youtube" or "vimeo".
NEXT_PUBLIC_VIDEO_ID=
NEXT_PUBLIC_VIDEO_HOST=youtube

# Google Analytics 4 (e.g. G-XXXXXXXXXX). When set, a cookie-consent banner
# appears and analytics/ads load only after the visitor accepts.
NEXT_PUBLIC_GA_ID=

# Google Ads conversion tag: the AW- id and the label after the slash
# (full send_to becomes AW-XXXXXXXXXX/label).
NEXT_PUBLIC_ADS_CONVERSION_ID=
NEXT_PUBLIC_ADS_CONVERSION_LABEL=
